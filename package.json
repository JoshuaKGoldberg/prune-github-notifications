{
	"name": "prune-github-notifications",
	"version": "0.7.0",
	"description": "Prunes GitHub notifications you don't care about, such as automated dependency bumps. 🧹",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JoshuaKGoldberg/prune-github-notifications.git"
	},
	"license": "MIT",
	"author": {
		"name": "Josh Goldberg",
		"email": "npm@joshuakgoldberg.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./lib/index.js"
	},
	"bin": "bin/index.js",
	"files": [
		"lib/"
	],
	"scripts": {
		"build": "tsdown",
		"format": "prettier .",
		"lint": "eslint . --max-warnings 0",
		"lint:knip": "knip",
		"lint:packages": "pnpm dedupe --check",
		"lint:spelling": "cspell \"**\" \".github/**/*\"",
		"prepare": "husky",
		"test": "vitest",
		"tsc": "tsc"
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"octokit-from-auth": "^0.3.2",
		"throttled-queue": "^3.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
		"@eslint/js": "10.0.1",
		"@eslint/markdown": "8.0.0",
		"@release-it/conventional-changelog": "10.0.6",
		"@types/node": "25.5.0",
		"@vitest/coverage-v8": "4.1.0",
		"@vitest/eslint-plugin": "1.6.12",
		"console-fail-test": "0.6.1",
		"create-typescript-app": "2.60.1",
		"cspell": "10.0.0",
		"eslint": "10.2.0",
		"eslint-plugin-jsdoc": "62.9.0",
		"eslint-plugin-jsonc": "3.1.2",
		"eslint-plugin-n": "17.24.0",
		"eslint-plugin-package-json": "0.91.0",
		"eslint-plugin-perfectionist": "5.8.0",
		"eslint-plugin-regexp": "3.1.0",
		"eslint-plugin-yml": "3.3.1",
		"husky": "9.1.7",
		"jsonc-eslint-parser": "3.1.0",
		"knip": "6.3.0",
		"lint-staged": "16.4.0",
		"prettier": "3.8.1",
		"prettier-plugin-curly": "0.4.1",
		"prettier-plugin-packagejson": "3.0.2",
		"prettier-plugin-sentences-per-line": "0.2.3",
		"prettier-plugin-sh": "0.18.0",
		"release-it": "19.2.4",
		"tsdown": "0.21.3",
		"typescript": "5.9.3",
		"typescript-eslint": "8.58.0",
		"vitest": "4.1.0"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"provenance": true
	}
}
